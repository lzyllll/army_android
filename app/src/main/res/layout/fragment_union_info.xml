<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F7"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title / Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvUnionName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Union Name"
                    android:textColor="#000000"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                
                <TextView
                    android:id="@+id/tvUnionLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_macos_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="Lv. --"
                    android:textColor="#007AFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Main Stats Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_macos_glass"
                android:orientation="vertical"
                android:padding="16dp">
                
                 <!-- Announcement Section -->
                 <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="公告 / Announcement"
                    android:textColor="#8E8E93"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>
                    
                 <TextView
                    android:id="@+id/tvAnnouncement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:text="Announcement content..."
                    android:textColor="#1C1C1E"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>
                    
                 <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#1A000000"
                    android:layout_marginBottom="16dp"/>

                <!-- Stats Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                         <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="总战力 / Power"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"/>
                         <TextView
                            android:id="@+id/tvUnionPower"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#000000"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    
                     <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                         <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="成员 / Members"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"/>
                         <TextView
                            android:id="@+id/tvUnionMembers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- / 100"
                            android:textColor="#000000"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Detailed Stats Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_macos_glass"
                android:orientation="vertical"
                android:divider="@drawable/divider_macos"
                android:showDividers="middle">
                
                <!-- Gold -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="总黄金数"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvTotalMoney"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>

                <!-- Total DPS -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="总 DPS"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvTotalDps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>
                
                 <!-- Battle Score -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="争霸总分数"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvBattleScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>
                
                 <!-- King Name -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="司令"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvKingName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>
                
            </LinearLayout>
            
             <!-- System Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_macos_glass"
                android:orientation="vertical"
                android:divider="@drawable/divider_macos"
                android:showDividers="middle">
                
                <!-- Union ID -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ID"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvUnionId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>

                <!-- Total Experience -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="总经验"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvTotalExp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>
                
                 <!-- Total Contribution -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="总贡献"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvTotalContribution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>
                
                <!-- Dissolve Date -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="解散日期"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvDissolveDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>
                
            </LinearLayout>

            <!-- Links & Limits Card -->
             <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_macos_glass"
                android:orientation="vertical"
                android:divider="@drawable/divider_macos"
                android:showDividers="middle">
                
                <!-- VIP Limit -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="VIP 限制"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvVipLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>

                <!-- DPS Limit -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DPS 限制"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvDpsLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"/>
                </LinearLayout>
                
                 <!-- URL -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="官贴地址"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#007AFF"
                        android:textSize="14sp"
                        android:autoLink="web"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
